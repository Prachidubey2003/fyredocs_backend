# Capacity-mode rate-limit overrides for LOAD TESTING ONLY.
#
# WHY: the suite drives traffic from one host/IP. The default limits (gateway
# API per plan, per-IP job-create/upload, per-IP login/signup) would throttle it
# and you'd measure the LIMITER, not the backend. Raise them for the test box so
# k6 finds the real capacity, then revert for production.
#
# HOW: append these to the TEST deployment's env, then redeploy, e.g.
#     cat scripts/k6/capacity-mode.env >> .env        # test box only!
#     ./deployment/deploy.sh
#   (Keep a backup of .env, or use a separate test .env. Do NOT commit/ship this
#    to production — these effectively disable abuse protection.)

# --- Gateway per-plan API limits (requests/min) ---
RATE_LIMIT_API_ANON=1000000
RATE_LIMIT_API_FREE=1000000
RATE_LIMIT_API_PRO=1000000
RATE_LIMIT_API_WINDOW=60s

# --- job-service per-IP limits ---
RATE_LIMIT_JOB_CREATE=1000000
RATE_LIMIT_UPLOAD=1000000

# --- auth-service per-IP limits (login/signup churn) ---
RATE_LIMIT_LOGIN=1000000
RATE_LIMIT_SIGNUP=1000000
RATE_LIMIT_REFRESH=1000000
RATE_LIMIT_WINDOW=60s
