{
  "name": "@fyredocs/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Fyredocs API. Types + runtime client.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:types": "openapi-typescript ../../docs/developer/swagger/openapi.yaml -o src/generated.ts",
    "check:types-fresh": "openapi-typescript ../../docs/developer/swagger/openapi.yaml -o /tmp/fyredocs-sdk-generated.ts && diff -q src/generated.ts /tmp/fyredocs-sdk-generated.ts"
  },
  "devDependencies": {
    "@types/node": "22.5.5",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.6.2",
    "vitest": "2.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "fyredocs",
    "pdf",
    "sdk",
    "api"
  ],
  "publishConfig": {
    "access": "public"
  }
}
