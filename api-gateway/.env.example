PORT="8080"
CORS_ALLOW_ORIGINS="http://localhost:5173,http://101.97.100.104:5173"
CORS_ALLOW_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Authorization,Content-Type,X-User-ID"
CORS_ALLOW_CREDENTIALS="true"

REDIS_ADDR="localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

AUTH_GUEST_PREFIX="guest"
AUTH_GUEST_SUFFIX="jobs"
AUTH_DENYLIST_ENABLED="true"
AUTH_DENYLIST_PREFIX="denylist:jwt"

JWT_ALLOWED_ALGS="HS256"
# SECURITY: DO NOT commit JWT_HS256_SECRET to version control
# For local development:
#   1. Copy this file to .env (gitignored)
#   2. Generate a secret: openssl rand -hex 32
#   3. Set JWT_HS256_SECRET="<generated-secret>" in .env
# For production:
#   Set via environment variable: export JWT_HS256_SECRET="your-secret-here"
JWT_HS256_SECRET=""
JWT_ISSUER=""
JWT_AUDIENCE=""
JWT_CLOCK_SKEW="60s"

UPLOAD_SERVICE_URL="http://upload-service:8081"
CONVERT_FROM_PDF_URL="http://convert-from-pdf:8082"
CONVERT_TO_PDF_URL="http://convert-to-pdf:8083"
ORGANIZE_PDF_URL="http://organize-pdf:8084"
