# Environment files with secrets
**/.env
.env.local
.env.*.local

# JWT secret file generated by deploy.sh
**/.jwt_secret

# Keep example files
!**/.env.example

# Compiled binaries
**/bin/

# Uploaded and converted files (local bind-mount storage)
files/uploads/*
!files/uploads/.gitkeep
files/outputs/*
!files/outputs/.gitkeep

# k6 load-test result reports (JSON/HTML), generated by scripts/k6/run.sh
scripts/k6/results/*
!scripts/k6/results/.gitkeep
