# Environment files with secrets
**/.env
.env.local
.env.*.local

# JWT secret file generated by deploy.sh
**/.jwt_secret

# Keep example files
!**/.env.example

# Compiled binaries
**/bin/

# Uploaded and converted files (local bind-mount storage)
files/uploads/*
!files/uploads/.gitkeep
files/outputs/*
!files/outputs/.gitkeep
