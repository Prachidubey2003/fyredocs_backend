# =============================================
# Fyredocs Backend — Environment Configuration
# =============================================
# Copy this file to .env and fill in values for your environment.
# NEVER commit the .env file — it is gitignored.
#
# Required variables are uncommented. Optional variables are commented
# out with their defaults — uncomment only if you need to override.

# ===================
# COMMON (all services)
# ===================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/fyredocs?sslmode=disable
POSTGRES_DB=fyredocs
POSTGRES_USER=fyredocs_admin
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=
# REDIS_ADDR=localhost:6379
# REDIS_DB=0
# Memory cap (compose passes this to redis-server --maxmemory). Keep it under
# the Redis container memory limit; volatile-lru evicts only keys with a TTL.
# REDIS_MAXMEMORY=400mb

# --- HTTP server timeouts (all services) ---
# Slowloris / slow-client protection. ReadHeader/Read/Idle are applied
# everywhere; WriteTimeout is only applied to non-streaming services (the
# gateway, job-service SSE, notification SSE and document exports leave it unset).
# HTTP_READ_HEADER_TIMEOUT=10s
# HTTP_READ_TIMEOUT=30s
# HTTP_IDLE_TIMEOUT=120s
# HTTP_WRITE_TIMEOUT=60s

# --- JWT ---
# deploy.sh auto-generates a strong 64-char secret into .jwt_secret and exports
# it. If you run WITHOUT deploy.sh, set a real secret (`openssl rand -hex 32`);
# services validate it is >= 64 chars and not a known default, and refuse to
# start otherwise. Never commit a real value.
# JWT_HS256_SECRET=
# JWT_ALLOWED_ALGS=HS256
# JWT_ISSUER=fyredocs
# JWT_AUDIENCE=fyredocs-api
# JWT_CLOCK_SKEW=60s

# --- Object storage (MinIO / S3) ---
# Files no longer use a shared volume — uploads/outputs live in object storage.
# MINIO_ROOT_* : MinIO superuser (you choose). Generate: openssl rand -base64 24
# S3_ACCESS_KEY / S3_SECRET_KEY : scoped app creds minio-init creates and every
#   service uses (keep different from root). Generate: openssl rand -hex 16
# PUBLIC_ORIGIN : the origin the browser uses to reach the stack — presigned
#   URLs are signed against it. This is the Caddy edge (dev: http://localhost;
#   prod: https://your-domain).
# PUBLIC_DOMAIN : set to your domain (e.g. docs.example.com) to have Caddy
#   terminate TLS with automatic certificates; leave unset for plain HTTP.
MINIO_ROOT_USER=fyredocs_root
MINIO_ROOT_PASSWORD=
S3_ACCESS_KEY=
S3_SECRET_KEY=
PUBLIC_ORIGIN=http://localhost
# PUBLIC_DOMAIN=

# --- Environment / production hardening ---
# Set ENVIRONMENT=production on real deployments. When set, every service
# refuses to start unless the config is secure:
#   AUTH_COOKIE_SECURE=true, DATABASE_URL without sslmode=disable, and
#   PUBLIC_ORIGIN/APP_BASE_URL over https:// (see shared/config EnforceProductionSecurity).
# ENVIRONMENT=production
# For production also set:
#   AUTH_COOKIE_SECURE=true
#   DATABASE_URL=...?sslmode=require   (or verify-full)
#   PUBLIC_ORIGIN=https://your-domain
#   APP_BASE_URL=https://your-domain

# --- Ads (optional): Content-Security-Policy allowlist for ad networks ---
# The Caddy edge serves the SPA under a strict CSP (same-origin only). To run ad
# networks, list their hosts here (space-separated) — the value is appended to the
# CSP script-src / img-src / connect-src / frame-src. You can list SEVERAL networks
# in one line. Most ad snippets also need 'unsafe-inline' (include it as shown).
# Empty (default) = strict CSP, no ads. NOTE: enabling ads relaxes XSS protection —
# that is expected and normal for ad-supported sites. After setting this, open the
# site and check the browser console for any remaining CSP "Refused to..." errors;
# each names the exact host to add here.
# Example (Google AdSense — add more networks' domains to the same line as needed):
# CSP_AD_DOMAINS='unsafe-inline' https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://tpc.googlesyndication.com https://adservice.google.com

# Optional — compose supplies these defaults; override only for non-default setups:
# S3_ENDPOINT=minio:9000
# S3_USE_SSL=false
# Bucket names double as the public URL path (/uploads/..., /outputs/... via
# the Caddy edge). On providers with a shared/global bucket namespace (e.g.
# AWS S3), generic names like "uploads" will collide — set unique names here.
# S3_BUCKET_UPLOADS=uploads
# S3_BUCKET_OUTPUTS=outputs
# S3_REGION=us-east-1
# UPLOAD_PART_SIZE_MB=8
# MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
# MINIO_MC_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z
# Input/output retention is set by *_JOB_TTL below (job-service's in-process
# cleanup loop), not a bucket lifecycle rule — minio-init clears any bucket
# expiry rule; stale incomplete multipart uploads are aborted by the cleanup loop.

# --- DB backups (offsite disaster recovery via the db-backup sidecar) ---
# Hourly pg_dump of the co-located Postgres, gzipped and uploaded to an
# S3-compatible bucket with rclone. This MUST be an EXTERNAL bucket — the
# on-server MinIO dies with the server and is not valid disaster recovery.
# Recommended: Cloudflare R2 (10 GB free, zero egress):
#   BACKUP_S3_PROVIDER=Cloudflare
#   BACKUP_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   BACKUP_S3_ACCESS_KEY / BACKUP_S3_SECRET_KEY = an R2 API token
# rclone S3 providers: Cloudflare | Backblaze (B2) | AWS | Minio | Other
BACKUP_S3_PROVIDER=Cloudflare
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=auto
# BACKUP_PREFIX=postgres/
# BACKUP_INTERVAL=3600   # seconds between backups (default hourly)
# BACKUP_RETAIN=10       # how many most-recent DB dumps to keep
# Empty-source protection (don't overwrite/prune a good backup with empty data):
# BACKUP_MIN_USERS=1              # skip DB backup if users < this (0 disables)
# BACKUP_MAX_DELETE=              # abort a file sync deleting more than N objects
# BACKUP_ALERT_WEBHOOK_URL=       # POST alert here when a guard trips (Slack/etc.)
# MinIO file buckets mirrored offsite each cycle (rclone sync, reuses S3_ACCESS_KEY/
# S3_SECRET_KEY as the source creds). Defaults to "outputs uploads" so in-flight
# user inputs survive a host loss; set to "outputs" to skip uploads, or empty to
# disable file backup. (Retention is DB-driven via job-service cleanup — there is
# no MinIO bucket lifecycle rule.)
# BACKUP_FILES_BUCKETS=outputs uploads
# BACKUP_FILES_PREFIX=minio/
# true = back up only registered (signed-in) users' outputs; guest jobs' files
# (processing_jobs.user_id IS NULL) are excluded. Guest files are ephemeral
# anyway (30-min expiry), so this is mainly a policy/space choice.
# BACKUP_FILES_REGISTERED_ONLY=false

# --- Auth ---
# AUTH_GUEST_PREFIX=guest
# AUTH_GUEST_SUFFIX=jobs
# AUTH_DENYLIST_ENABLED=true
# AUTH_DENYLIST_PREFIX=denylist:jwt
# AUTH_TRUST_GATEWAY_HEADERS=false

# --- Networking ---
# NATS_URL=nats://localhost:4222
# NATS HTTP monitoring endpoint (analytics-service NATS dashboard). Default http://nats:8222
# NATS_MONITOR_URL=http://nats:8222
# TRUSTED_PROXIES=127.0.0.1,::1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# LOG_MODE=

# ===================
# API GATEWAY
# ===================
# Internal-only port the api-gateway listens on and Caddy proxies to. It is NOT
# host-published (only Caddy's 80/443 are), so this value is never reachable from
# outside — setting a non-obvious, non-sequential port is purely defense-in-depth
# on the internal Docker network. Caddy and the analytics dashboard read the same
# value automatically. Change it to anything you like (avoid 8081-8091/4222/5432/
# 6379/8222/9000/9001/2002+, which are already used internally).
API_GATEWAY_PORT=47821
# CORS_ALLOW_ORIGINS=http://localhost:5173
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=Authorization,Content-Type,X-User-ID
# CORS_ALLOW_CREDENTIALS=true
# JOB_SERVICE_URL=http://job-service:8081
# AUTH_SERVICE_URL=http://auth-service:8086
# ANALYTICS_SERVICE_URL=http://analytics-service:8087

# --- Per-plan API rate limiting (/api/* routes) ---
# Sliding-window request ceilings per window, keyed by user (authenticated) or
# client IP (anonymous). /auth/* is limited separately by auth-service.
# RATE_LIMIT_API_WINDOW=1m
# RATE_LIMIT_API_ANON=30
# RATE_LIMIT_API_FREE=120
# RATE_LIMIT_API_PRO=600

# ===================
# AUTH SERVICE
# ===================
# JWT_ACCESS_TTL=8h
# JWT_REFRESH_TTL=168h
# AUTH_ACCESS_COOKIE=access_token
# AUTH_REFRESH_COOKIE=refresh_token
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax

# --- Rate Limiting ---
# RATE_LIMIT_LOGIN=5
# RATE_LIMIT_SIGNUP=3
# RATE_LIMIT_REFRESH=10
# RATE_LIMIT_FORGOT_PASSWORD=3
# RATE_LIMIT_RESET_PASSWORD=5
# RATE_LIMIT_WINDOW=60s

# --- Password Reset / Email (Resend) ---
# Leave RESEND_API_KEY empty in dev — the service falls back to NoopMailer
# and logs the reset link to stdout instead of emailing it.
# RESEND_API_KEY=
# RESET_EMAIL_FROM=no-reply@fyredocs.com
# APP_BASE_URL=http://localhost:5173
# PASSWORD_RESET_TOKEN_TTL=1h

# --- Proxy login (admin impersonation) ---
# 'admin'/'super-admin' can mint a short-lived token for another user via
# POST /auth/proxy-login. Disable the endpoint with PROXY_LOGIN_ENABLED=false.
# PROXY_LOGIN_ENABLED=true
# PROXY_LOGIN_TTL=30m
# RATE_LIMIT_PROXY_LOGIN=5

# ===================
# JOB SERVICE
# ===================
# UPLOAD_DIR=uploads
# OUTPUT_DIR=outputs
# MAX_UPLOAD_MB=50
# --- File retention (source of truth; covers BOTH input and output files) ---
# The cleanup-worker deletes a job's input + output when the job expires.
# Go durations. Defaults if unset: guest 30m, free 168h (7d), pro 720h (30d).
GUEST_JOB_TTL=30m
FREE_JOB_TTL=168h
PRO_JOB_TTL=720h
# UPLOAD_TTL=2h
# How long an incomplete (never-completed) multipart upload may sit before the
# cleanup-worker aborts it and frees its parts (Go duration; default 24h).
# MULTIPART_ABORT_TTL=24h
# QUEUE_PREFIX=queue
# PROCESSING_TIMEOUT=30m
# MAX_RETRIES=3

# ===================
# WORKERS (convert-from/to-pdf, organize-pdf, optimize-pdf)
# ===================
# Concurrent jobs processed per worker pod.
# WORKER_CONCURRENCY=2
# tmpfs scratch safety: reject jobs whose projected footprint (inputs + output)
# would exceed TMPFS_BUDGET_MB, and serialize jobs larger than
# LARGE_JOB_THRESHOLD_MB so two big jobs never share the scratch area.
# TMPFS_OUTPUT_FACTOR_PCT is the assumed worst-case output-to-input size ratio
# (200 = output up to 2x input). Raise the budget AND the compose tmpfs size
# together to support larger files.
# TMPFS_BUDGET_MB=900
# TMPFS_OUTPUT_FACTOR_PCT=200
# LARGE_JOB_THRESHOLD_MB=100

# --- convert-to-pdf: unoserver (LibreOffice) daemon pool ---
# Number of unoserver daemons launched per pod (on consecutive ports from
# UNOSERVER_PORT). Match to WORKER_CONCURRENCY; each daemon adds ~150-300 MB RAM.
# UNOSERVER_INSTANCES=2
# UNOSERVER_HOST=127.0.0.1
# UNOSERVER_PORT=2002

# --- convert-from-pdf: progress DB-write throttle ---
# DB progress is written only when it advances >= MIN_DELTA percent or after
# MIN_INTERVAL; NATS/SSE progress events are always published.
# PROGRESS_DB_MIN_DELTA=10
# PROGRESS_DB_MIN_INTERVAL=10s

# ===================
# OPTIMIZE-PDF: OCR
# ===================
# OCR_DEFAULT_LANGUAGE=eng
# OCR_DEFAULT_DPI=150

# ===================
# CLEANUP WORKER
# ===================
# CLEANUP_INTERVAL=15m

# ===================
# DOCUMENT-SERVICE: exports (bounded to avoid OOM under burst/large libraries)
# ===================
# EXPORT_MAX_CONCURRENCY=4     # max exports rendering at once
# EXPORT_MAX_ROWS=50000        # hard cap on documents per export
# EXPORT_QUEUE_WAIT=30s        # how long an export waits for a slot before failing (retryable)

# ===================
# ALERTING (Alertmanager)
# ===================
# Where Alertmanager POSTs firing alerts. Point at a Slack/PagerDuty/webhook
# bridge. Unset = alerts fire in Prometheus/Alertmanager UI but are not delivered.
# ALERTMANAGER_WEBHOOK_URL=
