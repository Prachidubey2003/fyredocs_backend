          { "matcher": { "id": "byName", "options": "convert-from-pdf:8082" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FACC15" } }] },
          { "matcher": { "id": "byName", "options": "convert-to-pdf:8083" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#EF4444" } }] },
          { "matcher": { "id": "byName", "options": "document-service:8089" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#A855F7" } }] },
          { "matcher": { "id": "byName", "options": "job-service:8081" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#EC4899" } }] },
          { "matcher": { "id": "byName", "options": "notification-service:8091" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#06B6D4" } }] },
          { "matcher": { "id": "byName", "options": "optimize-pdf:8085" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#84CC16" } }] },
          { "matcher": { "id": "byName", "options": "organize-pdf:8084" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F97316" } }] },
          { "matcher": { "id": "byName", "options": "user-service:8090" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#6366F1" } }] }
        ]
      },
      "options": {
        "legend": { "showLegend": false },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (instance) (rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{instance}}"
        }
