{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "fyredocs Overview",
  "uid": "fyredocs-overview",
  "tags": ["fyredocs"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by service (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (instance) (rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 request latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx error rate by service (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (instance) (rate(http_request_duration_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Jobs processed (per tool_type / status)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool_type, status) (rate(jobs_processed_total[5m]))",
          "legendFormat": "{{tool_type}} / {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Jobs failed (per tool_type / reason)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool_type, reason) (rate(jobs_failed_total[5m]))",
          "legendFormat": "{{tool_type}} / {{reason}}"
        }
      ]
    }
  ]
}
