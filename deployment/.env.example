# =============================================================================
# Fyredocs — deployment/.env  (used by docker-compose.yml in THIS directory)
# =============================================================================
# Copy to `deployment/.env` and fill in real values, then run:
#     docker compose -f deployment/docker-compose.yml up -d --build
#
# docker compose auto-loads a `.env` file sitting next to the compose file and
# substitutes ${VAR} references at parse time. NEVER commit the real .env.
#
# Only the variables compose actually substitutes (${...}) live here. The rest
# of the S3 config (S3_ENDPOINT=minio:9000, bucket names, S3_USE_SSL,
# UPLOAD_PART_SIZE_MB) is hardcoded in the compose file and needs no entry.
# -----------------------------------------------------------------------------

# --- PostgreSQL (Neon cloud) -------------------------------------------------
# Get this from the Neon dashboard: console.neon.tech → your project →
# "Connection Details" → copy the POOLED connection string (host ends in
# "-pooler"). Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# These three only feed the DATABASE_URL fallback in compose; with a full
# DATABASE_URL above you can leave them blank. Source: same Neon dashboard.
POSTGRES_DB=neondb
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Redis -------------------------------------------------------------------
# YOU choose this — it is set on the redis container (--requirepass) and reused
# by every service. Generate a strong one:  openssl rand -base64 24
REDIS_PASSWORD=

# --- JWT signing secret ------------------------------------------------------
# YOU generate this (HMAC secret for access/refresh tokens). 32+ bytes:
#     openssl rand -base64 48
# (deploy.sh auto-generates one if left unset.)
JWT_HS256_SECRET=

# --- MinIO root (admin) credentials ------------------------------------------
# YOU choose these — the MinIO superuser. Used only by the `minio` container
# and the one-shot `minio-init` job to bootstrap buckets + the scoped app user.
# Password must be >= 8 chars. Generate:  openssl rand -base64 24
MINIO_ROOT_USER=fyredocs_root
MINIO_ROOT_PASSWORD=

# --- S3 application credentials (scoped, NOT root) ---------------------------
# YOU choose these. `minio-init` creates this user with RW access limited to
# the two fyredocs buckets, and every service authenticates to S3 with them.
# Keep them different from the root creds above. Generate each:
#     openssl rand -hex 16
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Public origin (for presigned URLs) --------------------------------------
# The origin the BROWSER uses to reach the API gateway. Presigned upload/
# download URLs are signed against this host, so it must match exactly.
#   local dev (SPA served by gateway):  http://localhost:8080
#   production:                         https://app.yourdomain.com
PUBLIC_ORIGIN=http://localhost:8080

# --- OCR defaults (optional) -------------------------------------------------
# Safe to leave as-is. Override only to change default OCR language/resolution.
OCR_DEFAULT_LANGUAGE=eng
OCR_DEFAULT_DPI=150

# --- Password reset email (Resend) -------------------------------------------
# auth-service sends password-reset emails through Resend (resend.com). Leave
# RESEND_API_KEY blank to fall back to the no-op mailer, which only logs the
# reset link to stdout (fine for local/dev). For real delivery, set the API key
# and a verified sender. APP_BASE_URL is the frontend origin used to build the
# reset link in the email.
RESEND_API_KEY=
RESET_EMAIL_FROM=no-reply@fyredocs.com
APP_BASE_URL=http://localhost:5173

# --- Proxy login (admin impersonation) ---------------------------------------
# Lets an 'admin'/'super-admin' obtain a short-lived token for another user via
# POST /auth/proxy-login. Set PROXY_LOGIN_ENABLED=false to disable the endpoint
# entirely. PROXY_LOGIN_TTL bounds how long an impersonation token stays valid.
PROXY_LOGIN_ENABLED=true
PROXY_LOGIN_TTL=30m

# --- Object-storage knobs (optional — all have sane compose defaults) --------
# Uncomment only to override. Defaults shown.
# S3_ENDPOINT=minio:9000                 # internal address services use
# S3_USE_SSL=false
# S3_BUCKET_UPLOADS=fyredocs-uploads
# S3_BUCKET_OUTPUTS=fyredocs-outputs
# S3_REGION=us-east-1                    # signing region (MinIO ignores it)
# UPLOAD_PART_SIZE_MB=8                  # multipart part size (>= 5)
# MINIO_URL=http://minio:9000            # gateway → MinIO proxy target
# MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
# MINIO_MC_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z
# UPLOAD_EXPIRE_DAYS=2                   # uploads-bucket lifecycle: expire after
# UPLOAD_ABORT_INCOMPLETE_DAYS=1         # abort incomplete multipart after
