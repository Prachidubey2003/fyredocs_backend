DATABASE_URL="postgresql://user:password@localhost:5432/esydocs?sslmode=disable"
REDIS_ADDR="localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"
UPLOAD_DIR="uploads"
OUTPUT_DIR="outputs"
MAX_UPLOAD_MB="50"
GUEST_JOB_TTL="2h"
UPLOAD_TTL="2h"
MAX_RETRIES="3"
PROCESSING_TIMEOUT="30m"
QUEUE_PREFIX="queue"

# JWT settings
JWT_ALLOWED_ALGS="HS256"
# SECURITY: DO NOT commit JWT_HS256_SECRET to version control
# For local development:
#   1. Copy this file to .env (gitignored)
#   2. Generate a secret: openssl rand -hex 32
#   3. Set JWT_HS256_SECRET="<generated-secret>" in .env
# For production:
#   Set via environment variable: export JWT_HS256_SECRET="your-secret-here"
JWT_HS256_SECRET=""
JWT_ISSUER=""
JWT_AUDIENCE=""
JWT_CLOCK_SKEW="60s"
JWT_ACCESS_TTL="15m"

# Auth cookie settings
AUTH_REFRESH_TTL="720h"
AUTH_REFRESH_COOKIE="refresh_token"
AUTH_COOKIE_DOMAIN=""
# For local development without HTTPS, set to "false"
# For production with HTTPS, must be "true" (default)
AUTH_COOKIE_SECURE="true"
AUTH_COOKIE_SAMESITE="lax"

# Token denylist (for logout revocation)
AUTH_DENYLIST_ENABLED="true"
AUTH_DENYLIST_PREFIX="denylist:jwt"

# Rate limiting (per IP address)
RATE_LIMIT_LOGIN="5"
RATE_LIMIT_SIGNUP="3"
RATE_LIMIT_REFRESH="10"
RATE_LIMIT_WINDOW="60s"
