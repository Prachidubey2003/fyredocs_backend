									"});",
									"",
									"pm.test(\"Cookie is set\", function() {",
									"    pm.expect(pm.cookies.has('access_token')).to.be.true;",
									"});",
									"",
									"const response = pm.response.json();",
									"if (response.user && response.user.id) {",
									"    pm.environment.set('user_id', response.user.id);",
